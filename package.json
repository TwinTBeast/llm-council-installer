{
  "name": "llm-council-installer",
  "version": "1.0.0",
  "description": "LLM Council Plus Installer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.llmcouncil.installer",
    "productName": "LLM Council Plus Installer",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false
    },
    "files": [
      "main.js",
      "index.html",
      "icon.ico"
    ]
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "png2icons": "^2.0.1"
  }
}